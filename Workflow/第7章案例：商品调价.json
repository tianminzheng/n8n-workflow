    {
      "parameters": {
        "jsCode": "// 获取输入数据\nconst items = $input.all();\n\n// 第一个对象：包含output字段的数据\nconst firstItem = items[0].json;\n// 第二个对象：竞争对手数据\nconst secondItem = items[1].json;\n\n// 提取第一个对象中的价格（去掉¥符号并转为数字）\nconst competitorPriceStr = firstItem.output?.Price || firstItem.Price || '';\nconst competitorPrice = parseFloat(competitorPriceStr.replace(/[¥,]/g, '')) || 0;\n\n// 提取第二个对象中的价格（去掉¥符号并转为数字）\nconst ownerPriceStr = secondItem.price || '';\nconst ownerPrice = parseFloat(ownerPriceStr.replace(/[¥,]/g, '')) || 0;\n\n// 构建合并后的JSON对象\nconst mergedResult = {\n  // 书籍基本信息（从第一个对象获取）\n  title: firstItem.output?.title || firstItem.title,\n  author: firstItem.output?.author || firstItem.author,\n  isbn: firstItem.output?.ISBN || firstItem.ISBN || firstItem.isbn,\n  publisher: firstItem.output?.Publisher || firstItem.publisher,\n  publish_date: firstItem.output?.[\"Publisher Time\"] || firstItem.publish_date,  \n  competitor_price: competitorPrice,\n  owner_price: ownerPrice,  \n  competitor_url: secondItem.competitor_url\n};\n\n// 返回合并后的结果\nreturn [{ json: mergedResult }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
